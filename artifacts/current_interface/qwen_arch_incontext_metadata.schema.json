{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Qwen Architecture In-Context training metadata row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "image",
    "prompt",
    "context_image",
    "sample_id",
    "goal_lostate",
    "prompt_package",
    "verifier_refs"
  ],
  "properties": {
    "image": {
      "type": "string",
      "minLength": 1,
      "description": "target_full_semantic"
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "description": "compiled_text_prompt"
    },
    "context_image": {
      "type": "string",
      "minLength": 1,
      "description": "architecture_condition_image"
    },
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "goal_lostate": {
      "type": "string",
      "minLength": 1
    },
    "prompt_package": {
      "type": "string",
      "minLength": 1
    },
    "verifier_refs": {
      "type": "string",
      "minLength": 1
    }
  },
  "description": "Exact current Qwen full-semantic Architecture In-Context metadata row. Only the seven declared columns are valid."
}
