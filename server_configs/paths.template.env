# LoReflection server path template
# Copy this file to paths.local.env on the server and fill real paths.
# Do not commit paths.local.env.

LOREFLECTION_ROOT=/server/path/to/LoReflection

SEMLAYOUTDIFF_ROOT=/server/path/to/SemLayoutDiff
EDITROOM_ROOT=/server/path/to/EditRoom
DIFFSYNTH_ROOT=/server/path/to/DiffSynth-Studio
QWEN_VL_REPO=/server/path/to/qwen-vl-finetune

THREED_FRONT_ROOT=/server/path/to/3D-FRONT
THREED_FUTURE_ROOT=/server/path/to/3D-FUTURE

QWEN25_VL_MODEL_PATH=/server/path/to/Qwen2.5-VL-3B-Instruct
QWEN_IMAGE_MODEL_PATH=/server/path/to/Qwen-Image
DIFFSYNTH_INPAINT_MODEL_PATH=/server/path/to/DiffSynth-Studio/Qwen-Image-Blockwise-ControlNet-Inpaint
INSTANTX_INPAINT_MODEL_PATH=/server/path/to/InstantX/Qwen-Image-ControlNet-Inpainting

OUTPUT_ROOT=/server/path/to/loreflection_outputs

