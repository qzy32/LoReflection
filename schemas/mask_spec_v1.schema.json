{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loreflection.local/schemas/mask_spec_v1.schema.json",
  "title": "Mask Spec v1",
  "type": "object",
  "required": ["schema_version", "mask_id", "image_size_px", "items"],
  "properties": {
    "schema_version": { "const": "mask-spec-v1" },
    "mask_id": { "type": "string" },
    "image_size_px": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 1 }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mask_item" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "point": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "number" }
    },
    "mask_item": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["bbox", "polygon", "instance_ref"] },
        "bbox_px": { "$ref": "#/$defs/bbox" },
        "polygon_px": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point" }
        },
        "instance_ref": { "type": "string", "minLength": 1 },
        "dilate_px": { "type": "integer", "minimum": 0, "default": 0 },
        "value": { "enum": [255], "default": 255 }
      },
      "oneOf": [
        { "properties": { "type": { "const": "bbox" } }, "required": ["bbox_px"] },
        { "properties": { "type": { "const": "polygon" } }, "required": ["polygon_px"] },
        { "properties": { "type": { "const": "instance_ref" } }, "required": ["instance_ref"] }
      ],
      "additionalProperties": true
    }
  }
}
