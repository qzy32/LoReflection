{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loreflection.local/schemas/loreview_v1.schema.json",
  "title": "LoReview v1",
  "type": "object",
  "required": ["schema_version", "review_id", "task_id", "repair_round", "alignment", "issues", "summary"],
  "properties": {
    "schema_version": { "const": "loreview-v1" },
    "review_id": { "type": "string" },
    "task_id": { "type": "string" },
    "repair_round": { "type": "integer", "minimum": 0 },
    "alignment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["match_type"],
        "properties": {
          "slot_id": { "type": ["string", "null"] },
          "instance_id": { "type": ["string", "null"] },
          "match_type": { "enum": ["exact", "missing", "extra", "wrong-category candidate", "uncertain"] }
        },
        "additionalProperties": true
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "issue_type", "severity", "target_ref", "recommended_action_type"],
        "properties": {
          "issue_id": { "type": "string", "minLength": 1 },
          "issue_type": { "enum": ["entity_missing", "entity_extra", "category_mismatch", "relation_violation", "orientation_violation", "collision", "boundary_violation", "clearance_violation", "preservation_violation"] },
          "severity": { "enum": ["info", "warning", "error"] },
          "target_ref": { "type": "string", "minLength": 1 },
          "recommended_action_type": { "enum": ["ADD", "REMOVE", "TRANSLATE", "ROTATE", "SCALE", "REPLACE"] },
          "track": { "enum": ["A", "B", "LoRAM"] }
        },
        "additionalProperties": true
      }
    },
    "summary": { "type": "object" }
  },
  "additionalProperties": true
}
